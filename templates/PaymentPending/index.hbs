<<mjml lang="it">
  <mj-head>
    <mj-title>Attendi la conferma del pagamento</mj-title>
    <mj-font name="Titillium Web" href="https://selfcare.pagopa.it/assets/font/selfhostedfonts.css" />
    <mj-attributes>
      <mj-all font-family="Titillium Web, system-ui, sans-serif" />
    </mj-attributes>
    <mj-raw>
      <meta http-equiv="Content-Type" content="text/html" charset="UTF-8" />
      <meta name="color-scheme" content="light dark">
      <meta name="supported-color-schemes" content="light dark">
    </mj-raw>
  </mj-head>
  <mj-body css-class="mail-body">
    <mj-include path="../../styles/style.css" type="css" />
    <mj-wrapper>
      <mj-section css-class="header" padding-bottom="0px">
        <mj-column>
          <!-- pagoPA Logo -->
          <mj-include path="../../partials/header-logo.mjml" />
          <!-- Title & Main Message -->
          <mj-text css-class="title" font-weight="bold" align="left" padding-bottom="24px">
            <h1 style="font-size: 32px; line-height: 40px; margin: 0;">
              Attendi la conferma del pagamento
            </h1>
          </mj-text>
          <mj-spacer height="8px" css-class="spacer" />
        </mj-column>
      </mj-section>

      <mj-section css-class="section" padding="0px 25px">
        <mj-wrapper css-class="alert-block" border-left="4px solid #FFCB46" border-radius="8px" padding="16px">
          <mj-column>
            <mj-text font-size="16px" line-height="22px" align="left" color="#17324D" padding="0">
              Il pagamento non si &egrave; ancora concluso: riceverai a breve l&rsquo;esito via e-mail.
              L&rsquo;operazione pu&ograve; richiedere fino a 15 minuti.
            </mj-text>
          </mj-column>
        </mj-wrapper>
      </mj-section>

      {{> transactionSubject}}

      <!-- Divider -->
      <mj-include path="../../partials/divider.mjml" />

      <!-- Transaction Detail -->
      {{> transactionDetail}}

      <!-- Divider -->
      <mj-include path="../../partials/divider.mjml" />

      <!-- Footer -->
      <mj-include path="../../partials/footer.mjml" />
    </mj-wrapper>
  </mj-body>
  </mjml>